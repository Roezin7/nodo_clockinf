# --- Base de datos ---
DATABASE_URL=postgres://localhost:5432/clockai_dev

# --- Auth ---
JWT_SECRET=cambia-esto-en-produccion
JWT_REFRESH_SECRET=cambia-esto-tambien
PII_ENCRYPTION_KEY=base64-de-32-bytes-distinto-de-los-jwt
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
# Orígenes extra permitidos solo para desarrollo; producción usa mismo origen.
CORS_ORIGINS=http://localhost:5173

# --- Kiosco de pruebas público con enlace secreto (opcional) ---
# Habilita la organización que aparecerá en el kiosco público /demo/kiosk.
# No registra horas pagables ni fotos en el servidor; usa empleados activos
# sólo para identificar y guardar eventos aislados de demostración.
DEMO_KIOSK_ORGANIZATION_SLUG=modesto-packing

# --- Object storage (Cloudflare R2 / S3-compatible) ---
# Si se dejan vacíos, el server usa ./uploads-local. El arranque de producción
# falla si no hay bucket y credenciales duraderas.
S3_ENDPOINT=
S3_BUCKET=clockai-photos
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto

# --- Identidad facial ---
# Valor seguro por omisión: conserva evidencia y manda todo a revisión humana.
FACE_PROVIDER=review_only

# Comparación 1:1 opcional. CompareFaces no es prueba de vida, por lo que un
# match de fotografía fija nunca se aprueba automáticamente.
FACE_AWS_REGION=us-west-2
FACE_SIMILARITY_THRESHOLD=95
FACE_SESSION_TTL_SECONDS=600

# --- Notificaciones push PWA (opcional) ---
# Deja las tres vacías para desactivar Web Push. Si configuras una, las tres
# son obligatorias. Genera el par una sola vez con: npx web-push generate-vapid-keys
VAPID_SUBJECT=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Planta ---
PLANT_TIMEZONE=America/Los_Angeles

PORT=3001

# --- Bootstrap manual (no se usa al arrancar el contenedor) ---
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
# Solo si es el primer bootstrap en producción:
ALLOW_PRODUCTION_BOOTSTRAP=no

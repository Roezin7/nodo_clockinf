# --- Base de datos ---
DATABASE_URL=postgres://localhost:5432/clockai_dev

# --- Auth ---
JWT_SECRET=cambia-esto-en-produccion
JWT_REFRESH_SECRET=cambia-esto-tambien
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# Token estático que autentica al kiosco (tablet). Genera uno largo y aleatorio.
KIOSK_DEVICE_TOKEN=kiosk-dev-token

# --- Object storage (Cloudflare R2 / S3-compatible) ---
# Si se dejan vacíos, el server usa almacenamiento local en ./uploads-local (solo dev).
S3_ENDPOINT=
S3_BUCKET=clockai-photos
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto

# --- Planta ---
PLANT_TIMEZONE=America/Mexico_City

PORT=3001
